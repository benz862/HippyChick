# Next.js only reads `.env`, `.env.local`, `.env.production`, etc. — NOT this file.
# Copy this file to `.env.local` in this same folder (`site/`), fill in values, then restart `npm run dev`.

# Supabase → Project Settings → API (Project URL + anon public key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your live or preview site URL, no trailing slash (metadata + sitemap)
NEXT_PUBLIC_SITE_URL=

# --- Contact-form email notifications (optional, via Resend: https://resend.com) ---
# If RESEND_API_KEY is unset, the form still works — it just won't send an email.
RESEND_API_KEY=
# Where form submissions are emailed. Defaults to info@hippychicklife.com.
NOTIFY_EMAIL=info@hippychicklife.com
# Verified sender in Resend. Use `onboarding@resend.dev` for testing; switch to
# a verified hippychicklife.com address once the domain is added in Resend.
NOTIFY_FROM=Hippy Chick Life <onboarding@resend.dev>
